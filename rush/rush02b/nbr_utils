// Função para extrair os dígitos relevantes da escala atual
void extrairDigitosEscala(const char *numero, const char *escalaCheia, char *resultado) {
	int lenNumero = strlen(numero);
	int lenEscala = strlen(escalaCheia);
	int diff = lenNumero - lenEscala;

	if (diff < 0) {
		// O número é menor que a escala, preenche com zeros à esquerda
		sprintf(resultado, "%0*d", lenEscala, 0);
		strncpy(resultado + (lenEscala - lenNumero), numero, lenNumero);
	} else {
		// Extrai os dígitos relevantes
		strncpy(resultado, numero + diff, lenEscala);
		resultado[lenEscala] = '\0';
	}
}

void preencherZeros(char *numero) {
	int len = strlen(numero);
	int escala = 3; // Assume-se que a escala é de 3 em 3 dígitos
	int zerosNecessarios = escala - (len % escala);

	if (zerosNecessarios == escala) {
		return; // Não precisa adicionar zeros
	}

	// Aloca espaço para os zeros adicionais
	char *novoNumero = (char *)malloc(len + zerosNecessarios + 1);

	// Preenche com zeros
	int i = 0;
	while (i < zerosNecessarios) {
		novoNumero[i] = '0';
		i++;
	}

	// Copia o número original
	strcpy(novoNumero + zerosNecessarios, numero);

	// Copia o novo número de volta para o original
	strcpy(numero, novoNumero);

	free(novoNumero);
}
