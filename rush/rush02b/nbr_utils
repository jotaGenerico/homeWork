int ft_atoa(const char *valor) {
	int resultado = 0;
	int i = 0;

	while (i < 3) {
		resultado = resultado * 10 + (valor[i] - '0');
		i++;
	}
	return resultado;
}

int ft_validar_nbr(char *str) {
	int count = 0;

	while (*str != '\0') {
		if (*str < '0' || *str > '9') {
			return -1;
		ft_validar_nbr(char *str)}
		count++;
		if (count > 40) {
			return -1;
		}
		str++;
	}

	if (count == 0) {
		return -1;
	}

	return 1;
}

